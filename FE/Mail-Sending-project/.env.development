# Dev-only API config
# Change this to your backend origin (no trailing slash)
VITE_API_PROXY_TARGET=http://localhost:5000

# Keep relative base so calls go through Vite proxy in dev
VITE_API_BASE_URL=/api/v1

# Use JWT from login response for protected APIs
VITE_API_AUTH_MODE=bearer
VITE_API_BEARER_TOKEN=
